<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- Drop flat_percentage_amount from m_wc_loan_product (EIR-only, no flat amortization for WCL) -->
    <changeSet author="fineract" id="wclp-0007-1-drop-flat-percentage-amount">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_product"/>
            <columnExists tableName="m_wc_loan_product" columnName="flat_percentage_amount"/>
        </preConditions>
        <dropColumn tableName="m_wc_loan_product" columnName="flat_percentage_amount"/>
    </changeSet>

    <!-- Drop flat_percentage_amount_overridable from m_wc_loan_product_configurable_attributes -->
    <changeSet author="fineract" id="wclp-0007-2-drop-flat-percentage-amount-overridable">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_product_configurable_attributes"/>
            <columnExists tableName="m_wc_loan_product_configurable_attributes" columnName="flat_percentage_amount_overridable"/>
        </preConditions>
        <dropColumn tableName="m_wc_loan_product_configurable_attributes" columnName="flat_percentage_amount_overridable"/>
    </changeSet>

</databaseChangeLog>
