<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <!-- Add business columns to existing m_wc_loan (table and id, version, created_by, last_modified_by, created_on_utc, last_modified_on_utc already exist) -->
    <changeSet author="fineract" id="wcl-0005-1">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
        </preConditions>
        <addColumn tableName="m_wc_loan">
            <column defaultValueComputed="NULL" name="client_id" type="BIGINT"/>
            <column defaultValueComputed="NULL" name="fund_id" type="BIGINT"/>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column defaultValueComputed="NULL" name="submittedon_date" type="date"/>
            <column defaultValueComputed="NULL" name="rejectedon_date" type="date"/>
            <column defaultValueComputed="NULL" name="rejectedon_userid" type="BIGINT"/>
            <column defaultValueComputed="NULL" name="approvedon_date" type="date"/>
            <column defaultValueComputed="NULL" name="approvedon_userid" type="BIGINT"/>
            <column defaultValueComputed="NULL" name="closedon_date" type="date"/>
            <column defaultValueComputed="NULL" name="closedon_userid" type="BIGINT"/>
            <column defaultValueComputed="NULL" name="expected_maturedon_date" type="date"/>
            <column defaultValueComputed="NULL" name="maturedon_date" type="date"/>
            <column name="principal_amount_proposed" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_principal" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <!-- Embedded WCLoanProductRelatedDetails (currency + term fields) -->
            <column defaultValueComputed="NULL" name="currency_code" type="VARCHAR(3)"/>
            <column defaultValueComputed="NULL" name="currency_digits" type="SMALLINT"/>
            <column defaultValueComputed="NULL" name="currency_multiplesof" type="SMALLINT"/>
            <column defaultValueComputed="NULL" name="principal_amount" type="DECIMAL(19, 6)"/>
            <column defaultValueComputed="NULL" name="period_payment_rate" type="DECIMAL(19, 6)"/>
            <column defaultValueComputed="NULL" name="repayment_every" type="INT"/>
            <column defaultValueComputed="NULL" name="repayment_frequency_enum" type="VARCHAR(50)"/>
            <column defaultValueComputed="NULL" name="amortization_type" type="VARCHAR(50)"/>
            <column defaultValueComputed="NULL" name="npv_day_count" type="INT"/>
            <column defaultValueComputed="NULL" name="discount" type="DECIMAL(19, 6)"/>
            <column defaultValueComputed="NULL" name="delinquency_bucket_classification_id" type="BIGINT"/>
            <column defaultValueComputed="NULL" name="loan_counter" type="INT"/>
            <column defaultValueComputed="NULL" name="loan_product_counter" type="INT"/>
        </addColumn>
    </changeSet>

    <!-- m_wc_loan_balance: running balances (one row per loan) -->
    <changeSet author="fineract" id="wcl-0005-1-balance">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <not>
                <tableExists tableName="m_wc_loan_balance"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_balance">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="wc_loan_id" type="BIGINT">
                <constraints nullable="false" unique="true" foreignKeyName="FK_m_wc_loan_balance_loan" referencedTableName="m_wc_loan" referencedColumnNames="id"/>
            </column>
            <column name="principal_outstanding" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="total_paid_principal" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="total_payment" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="realized_income" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="unrealized_income" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Add UTC datetime columns for m_wc_loan_balance (MySQL) -->
    <changeSet author="fineract" id="wcl-0005-1-balance-utc-mysql" context="mysql">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_balance"/>
            <not>
                <columnExists tableName="m_wc_loan_balance" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_balance">
            <column name="created_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add UTC datetime columns for m_wc_loan_balance (PostgreSQL) -->
    <changeSet author="fineract" id="wcl-0005-1-balance-utc-pg" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_balance"/>
            <not>
                <columnExists tableName="m_wc_loan_balance" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_balance">
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Change loan_status_id from bigint to SMALLINT to align with core loan table and store numeric status id -->
    <changeSet author="fineract" id="wcl-0005-1b">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <columnExists tableName="m_wc_loan" columnName="loan_status_id"/>
        </preConditions>
        <modifyDataType tableName="m_wc_loan" columnName="loan_status_id" newDataType="SMALLINT"/>
    </changeSet>

    <!-- WCLoanPaymentAllocationRule -->
    <changeSet author="fineract" id="wcl-0005-2">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_payment_allocation_rule"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_payment_allocation_rule">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="wc_loan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="m_wc_loan_payment_allocation_rule_loan_fk" referencedTableName="m_wc_loan" referencedColumnNames="id"/>
            </column>
            <column name="transaction_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="allocation_types" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Add UTC datetime columns for audit on payment allocation rule (MySQL) -->
    <changeSet author="fineract" id="wcl-0005-3" context="mysql">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_payment_allocation_rule"/>
            <not>
                <columnExists tableName="m_wc_loan_payment_allocation_rule" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_payment_allocation_rule">
            <column name="created_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add UTC datetime columns for audit on payment allocation rule (PostgreSQL) -->
    <changeSet author="fineract" id="wcl-0005-3-pg" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_payment_allocation_rule"/>
            <not>
                <columnExists tableName="m_wc_loan_payment_allocation_rule" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_payment_allocation_rule">
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Working Capital Loan Note -->
    <changeSet author="fineract" id="wcl-0005-4">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_note"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_note">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="wc_loan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="FK_m_wc_loan_note_loan" referencedTableName="m_wc_loan" referencedColumnNames="id"/>
            </column>
            <column name="note" type="VARCHAR(1000)"/>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Add UTC datetime columns for m_wc_loan_note (MySQL) -->
    <changeSet author="fineract" id="wcl-0005-5-mysql" context="mysql">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_note"/>
            <not>
                <columnExists tableName="m_wc_loan_note" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_note">
            <column name="created_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add UTC datetime columns for m_wc_loan_note (PostgreSQL) -->
    <changeSet author="fineract" id="wcl-0005-5-pg" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_note"/>
            <not>
                <columnExists tableName="m_wc_loan_note" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_note">
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Foreign keys for m_wc_loan_note (audit columns) -->
    <changeSet author="fineract" id="wcl-0005-6">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_note"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_m_wc_loan_note_created_by"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_wc_loan_note"
                                 constraintName="FK_m_wc_loan_note_created_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_wc_loan_note"
                                 constraintName="FK_m_wc_loan_note_last_modified_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
    </changeSet>

    <!-- Foreign key constraints for m_wc_loan -->
    <changeSet author="fineract" id="wcl-0005-7">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <columnExists tableName="m_wc_loan" columnName="client_id"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_m_wc_loan_client"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="client_id" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_client" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_client" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="fund_id" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_fund" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_fund" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="product_id" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_product" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_wc_loan_product" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="rejectedon_userid" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_rejected_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="approvedon_userid" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_approved_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="closedon_userid" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_closed_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_created_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_last_modified_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="delinquency_bucket_classification_id" baseTableName="m_wc_loan"
                                 constraintName="FK_m_wc_loan_delinquency_bucket" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_delinquency_bucket" validate="true"/>
    </changeSet>

    <!-- Foreign keys for child tables and audit on payment allocation rule -->
    <changeSet author="fineract" id="wcl-0005-8">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_payment_allocation_rule"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_m_wc_loan_par_created_by"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_wc_loan_payment_allocation_rule"
                                 constraintName="FK_m_wc_loan_par_created_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_wc_loan_payment_allocation_rule"
                                 constraintName="FK_m_wc_loan_par_last_modified_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
    </changeSet>

    <!-- Unique constraint for payment allocation rule (wc_loan_id + transaction_type) -->
    <changeSet author="fineract" id="wcl-0005-9">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_payment_allocation_rule"/>
            <not>
                <indexExists tableName="m_wc_loan_payment_allocation_rule" indexName="uq_m_wc_loan_payment_allocation_rule"/>
            </not>
        </preConditions>
        <addUniqueConstraint columnNames="wc_loan_id, transaction_type" constraintName="uq_m_wc_loan_payment_allocation_rule" tableName="m_wc_loan_payment_allocation_rule"/>
    </changeSet>

    <!-- Indexes -->
    <changeSet author="fineract" id="wcl-0005-10">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <columnExists tableName="m_wc_loan" columnName="client_id"/>
            <not>
                <indexExists tableName="m_wc_loan" indexName="IND_m_wc_loan_client_id"/>
            </not>
        </preConditions>
        <createIndex tableName="m_wc_loan" indexName="IND_m_wc_loan_client_id">
            <column name="client_id"/>
        </createIndex>
        <createIndex tableName="m_wc_loan" indexName="IND_m_wc_loan_product_id">
            <column name="product_id"/>
        </createIndex>
        <createIndex tableName="m_wc_loan" indexName="IND_m_wc_loan_loan_status_id">
            <column name="loan_status_id"/>
        </createIndex>
        <createIndex tableName="m_wc_loan_payment_allocation_rule" indexName="IND_m_wc_loan_payment_allocation_rule_loan_id">
            <column name="wc_loan_id"/>
        </createIndex>
    </changeSet>

    <!-- Permissions for Working Capital Loan (account) -->
    <changeSet id="wcl-0005-11" author="fineract">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM m_permission WHERE code = 'READ_WORKINGCAPITALLOAN'</sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="READ_WORKINGCAPITALLOAN"/>
            <column name="entity_name" value="WORKINGCAPITALLOAN"/>
            <column name="action_name" value="READ"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="CREATE_WORKINGCAPITALLOAN"/>
            <column name="entity_name" value="WORKINGCAPITALLOAN"/>
            <column name="action_name" value="CREATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="UPDATE_WORKINGCAPITALLOAN"/>
            <column name="entity_name" value="WORKINGCAPITALLOAN"/>
            <column name="action_name" value="UPDATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="DELETE_WORKINGCAPITALLOAN"/>
            <column name="entity_name" value="WORKINGCAPITALLOAN"/>
            <column name="action_name" value="DELETE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>
