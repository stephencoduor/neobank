<!--
    Move expected/actual disbursement fields from m_wc_loan into m_wc_loan_disbursement_detail.
    Expected: date, amount, maturityDate. Actual: date, amount, disbursed by.
-->
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet author="fineract" id="wcl-0006-1">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <not>
                <tableExists tableName="m_wc_loan_disbursement_detail"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_disbursement_detail">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="wc_loan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="FK_m_wc_loan_disbursement_detail_loan" referencedTableName="m_wc_loan" referencedColumnNames="id"/>
            </column>
            <column name="expected_disburse_date" type="date"/>
            <column name="expected_amount" type="DECIMAL(19, 6)"/>
            <column name="expected_maturity_date" type="date"/>
            <column name="actual_disburse_date" type="date"/>
            <column name="actual_amount" type="DECIMAL(19, 6)"/>
            <column name="disbursedon_userid" type="BIGINT">
                <constraints nullable="true" foreignKeyName="FK_m_wc_loan_disbursement_detail_user" referencedTableName="m_appuser" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="fineract" id="wcl-0006-2">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <foreignKeyConstraintExists foreignKeyName="FK_m_wc_loan_disbursed_by"/>
        </preConditions>
        <dropForeignKeyConstraint baseTableName="m_wc_loan" constraintName="FK_m_wc_loan_disbursed_by"/>
    </changeSet>

    <changeSet author="fineract" id="wcl-0006-3">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <columnExists tableName="m_wc_loan" columnName="expected_disbursedon_date"/>
        </preConditions>
        <dropColumn tableName="m_wc_loan">
            <column name="expected_disbursedon_date"/>
            <column name="disbursedon_date"/>
            <column name="disbursedon_userid"/>
        </dropColumn>
    </changeSet>
</databaseChangeLog>
