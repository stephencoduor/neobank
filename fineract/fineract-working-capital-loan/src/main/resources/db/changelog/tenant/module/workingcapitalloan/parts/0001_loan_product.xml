<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <!-- Main Working Capital Loan Product table -->
    <changeSet author="fineract" id="wclp-0001-1">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_product"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_product">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <!-- Details category -->
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="short_name" type="VARCHAR(4)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="external_id" type="VARCHAR(100)">
                <constraints unique="true"/>
            </column>
            <column defaultValueComputed="NULL" name="fund_id" type="BIGINT"/>
            <column defaultValueComputed="NULL" name="start_date" type="date"/>
            <column defaultValueComputed="NULL" name="close_date" type="date"/>
            <column name="description" type="VARCHAR(500)"/>

            <!-- Currency category (embedded) -->
            <column name="currency_code" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="currency_digits" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column defaultValueComputed="NULL" name="currency_multiplesof" type="SMALLINT"/>

            <!-- Settings category (embedded) -->
            <column name="amortization_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column defaultValueComputed="NULL" name="flat_percentage_amount" type="DECIMAL(19, 6)"/>
            <column defaultValueComputed="NULL" name="delinquency_bucket_classification_id" type="BIGINT"/>
            <column name="npv_day_count" type="INT">
                <constraints nullable="false"/>
            </column>

            <!-- Term category (embedded) -->
            <column defaultValueComputed="NULL" name="min_principal_amount" type="DECIMAL(19, 6)"/>
            <column name="principal_amount" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column defaultValueComputed="NULL" name="max_principal_amount" type="DECIMAL(19, 6)"/>
            <column defaultValueComputed="NULL" name="min_period_payment_rate" type="DECIMAL(19, 6)"/>
            <column name="period_payment_rate" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column defaultValueComputed="NULL" name="max_period_payment_rate" type="DECIMAL(19, 6)"/>
            <column defaultValueComputed="NULL" name="discount" type="DECIMAL(19, 6)"/>
            <column name="repayment_every" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="repayment_frequency_enum" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Payment Allocation Rule table -->
    <changeSet author="fineract" id="wclp-0001-2">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_product_payment_allocation_rule"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_product_payment_allocation_rule">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="wc_loan_product_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="m_wc_loan_product_payment_allocation_rule_fk" referencedTableName="m_wc_loan_product" referencedColumnNames="id"/>
            </column>
            <column name="transaction_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="allocation_types" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Configurable Attributes table -->
    <changeSet author="fineract" id="wclp-0001-3">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_product_configurable_attributes"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_product_configurable_attributes">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="wc_loan_product_id" type="BIGINT">
                <constraints nullable="false" unique="true" foreignKeyName="m_wc_loan_product_configurable_attributes_fk" referencedTableName="m_wc_loan_product" referencedColumnNames="id"/>
            </column>
            <column defaultValueComputed="NULL" name="flat_percentage_amount_overridable" type="BOOLEAN"/>
            <column defaultValueComputed="NULL" name="delinquency_bucket_classification_overridable" type="BOOLEAN"/>
            <column defaultValueComputed="NULL" name="discount_default_overridable" type="BOOLEAN"/>
            <column defaultValueComputed="NULL" name="period_payment_frequency_overridable" type="BOOLEAN"/>
            <column defaultValueComputed="NULL" name="period_payment_frequency_type_overridable" type="BOOLEAN"/>
        </createTable>
    </changeSet>

    <!-- Add UTC datetime columns for audit fields (MySQL) -->
    <changeSet author="fineract" id="wclp-0001-4" context="mysql">
        <addColumn tableName="m_wc_loan_product_payment_allocation_rule">
            <column name="created_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add UTC datetime columns for audit fields (PostgreSQL) -->
    <changeSet author="fineract" id="wclp-0001-4-pg" context="postgresql">
        <addColumn tableName="m_wc_loan_product_payment_allocation_rule">
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add foreign key constraints -->
    <changeSet author="fineract" id="wclp-0001-5">
        <addForeignKeyConstraint baseColumnNames="fund_id" baseTableName="m_wc_loan_product"
                                 constraintName="FK_wc_loan_product_fund" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_fund" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="delinquency_bucket_classification_id" baseTableName="m_wc_loan_product"
                                 constraintName="FK_wc_loan_product_delinquency_bucket" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_delinquency_bucket" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_wc_loan_product_payment_allocation_rule"
                                 constraintName="FK_wc_loan_product_payment_allocation_rule_created_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_wc_loan_product_payment_allocation_rule"
                                 constraintName="FK_wc_loan_product_payment_allocation_rule_last_modified_by" deferrable="false"
                                 initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
    </changeSet>

    <!-- Add indexes -->
    <changeSet author="fineract" id="wclp-0001-6">
        <createIndex tableName="m_wc_loan_product" indexName="IND_wc_loan_product_fund_id">
            <column name="fund_id"/>
        </createIndex>
        <createIndex tableName="m_wc_loan_product" indexName="IND_wc_loan_product_external_id">
            <column name="external_id"/>
        </createIndex>
        <createIndex tableName="m_wc_loan_product_payment_allocation_rule" indexName="IND_wc_loan_product_payment_allocation_rule_product_id">
            <column name="wc_loan_product_id"/>
        </createIndex>
        <createIndex tableName="m_wc_loan_product_configurable_attributes" indexName="IND_wc_loan_product_configurable_attributes_product_id">
            <column name="wc_loan_product_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="wclp-0001-7" author="fineract">
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="READ_WORKINGCAPITALLOANPRODUCT"/>
            <column name="entity_name" value="WORKINGCAPITALLOANPRODUCT"/>
            <column name="action_name" value="READ"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="CREATE_WORKINGCAPITALLOANPRODUCT"/>
            <column name="entity_name" value="WORKINGCAPITALLOANPRODUCT"/>
            <column name="action_name" value="CREATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="UPDATE_WORKINGCAPITALLOANPRODUCT"/>
            <column name="entity_name" value="WORKINGCAPITALLOANPRODUCT"/>
            <column name="action_name" value="UPDATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="organisation"/>
            <column name="code" value="DELETE_WORKINGCAPITALLOANPRODUCT"/>
            <column name="entity_name" value="WORKINGCAPITALLOANPRODUCT"/>
            <column name="action_name" value="DELETE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>
