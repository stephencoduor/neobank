        </preConditions>
        <addForeignKeyConstraint baseTableName="m_loan_originator" baseColumnNames="originator_type_cv_id"
                                 referencedTableName="m_code_value" referencedColumnNames="id"
                                 constraintName="FK_loan_originator_type_cv" onDelete="RESTRICT" onUpdate="RESTRICT"/>
    </changeSet>

